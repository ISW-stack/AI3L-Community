# ==========================================================================
# AI3L Community — Production Environment (.env)
#
# Target: Hetzner CPX32 (4 vCPU / 8 GB / 160 GB) — Singapore
# Storage: Cloudflare R2  |  CDN: Cloudflare Free  |  Backup: Hetzner BX11
#
# IMPORTANT: Generate ALL secrets before first deploy:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
# ==========================================================================

# =====================
# FastAPI
# =====================
FASTAPI_ENV=production
FASTAPI_DEBUG=false
FASTAPI_HOST=0.0.0.0
FASTAPI_PORT=8000
FASTAPI_WORKERS=4
SECRET_KEY=<generate-a-strong-random-secret>

# =====================
# PostgreSQL
# =====================
POSTGRES_USER=ai3l
POSTGRES_PASSWORD=<generate-a-strong-random-password>
POSTGRES_DB=ai3l_community
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
# Set to true if PostgreSQL is on a remote host (not same Docker network)
DATABASE_SSL=false

# Tuning for Hetzner CPX32 (8 GB RAM, PG container limit 3 GB)
PG_SHARED_BUFFERS=2GB
PG_EFFECTIVE_CACHE=2GB
PG_WORK_MEM=4MB
PG_MAX_CONNECTIONS=50

# =====================
# Redis
# =====================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=<generate-a-strong-random-password>
# Set to true if Redis is on a remote host (not same Docker network)
REDIS_SSL=false

# =====================
# JWT
# =====================
JWT_SECRET_KEY=<generate-a-strong-random-secret-at-least-32-chars>
JWT_ALGORITHM=HS256
JWT_GUEST_EXPIRE_MINUTES=45
JWT_MEMBER_EXPIRE_MINUTES=180
JWT_ADMIN_EXPIRE_MINUTES=300
JWT_SUPER_ADMIN_EXPIRE_MINUTES=480

# =====================
# CORS — set to your actual domain
# =====================
CORS_ORIGINS=https://yourdomain.com

# =====================
# Cookie — set to your actual domain
# =====================
COOKIE_SECURE=true
COOKIE_SAMESITE=lax
COOKIE_DOMAIN=yourdomain.com

# =====================
# S3-compatible storage — Cloudflare R2
# =====================
# Create R2 bucket + API token at: https://dash.cloudflare.com → R2
S3_ACCESS_KEY_ID=<r2-access-key-id>
S3_SECRET_ACCESS_KEY=<r2-secret-access-key>
S3_ENDPOINT=<account-id>.r2.cloudflarestorage.com
S3_BUCKET_NAME=ai3l-uploads
S3_USE_SSL=true
S3_REGION=auto
# Public URL: either R2 custom domain or R2.dev subdomain
S3_PUBLIC_URL=https://storage.yourdomain.com

# =====================
# nginx — CSP origin for presigned URLs (same as S3_PUBLIC_URL)
# =====================
STORAGE_CSP_ORIGIN=https://storage.yourdomain.com

# =====================
# nginx — domain name for HTTPS server_name
# =====================
# REQUIRED for production. Used by docker-entrypoint.sh to set nginx server_name.
# Without this, nginx matches ANY Host header (host header poisoning risk).
SERVER_DOMAIN=yourdomain.com

# =====================
# Super Admin
# =====================
SUPER_ADMIN_USERNAME=superadmin
SUPER_ADMIN_PASSWORD=<generate-a-strong-random-password>

# =====================
# Logging
# =====================
LOG_LEVEL=INFO
LOG_FORMAT=json

# =====================
# Trusted Hosts (your domain + www)
# =====================
TRUSTED_HOSTS=yourdomain.com,www.yourdomain.com

# =====================
# Optional: Sentry error tracking
# =====================
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# =====================
# Optional: VirusTotal file scanning
# =====================
VT_API_KEY=
