{
  "extends": "@vue/tsconfig/tsconfig.dom.json",
  "include": [
    "src/**/__tests__/*",
    "src/**/*.spec.ts",
    "src/**/*.spec.tsx",
    "src/**/*.vue"
  ],
  "compilerOptions": {
    "composite": true,
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.vitest.tsbuildinfo",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    },
    "types": ["vitest/globals", "node"]
  }
}
