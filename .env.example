# =====================
# PostgreSQL
# =====================
POSTGRES_USER=ai3l
POSTGRES_PASSWORD=changeme_postgres
POSTGRES_DB=ai3l_community
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# =====================
# Redis
# =====================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=changeme_redis
REDIS_URL=redis://:${REDIS_PASSWORD}@${REDIS_HOST}:${REDIS_PORT}/0

# =====================
# FastAPI
# =====================
FASTAPI_ENV=development
FASTAPI_DEBUG=true
FASTAPI_HOST=0.0.0.0
FASTAPI_PORT=8000
FASTAPI_WORKERS=1
SECRET_KEY=changeme_secret_key_at_least_32_characters_long

# =====================
# JWT
# =====================
JWT_SECRET_KEY=changeme_jwt_secret_key
JWT_ALGORITHM=HS256
JWT_GUEST_EXPIRE_MINUTES=45
JWT_MEMBER_EXPIRE_MINUTES=180
JWT_ADMIN_EXPIRE_MINUTES=300
JWT_SUPER_ADMIN_EXPIRE_MINUTES=480

# =====================
# CORS
# =====================
CORS_ORIGINS=http://localhost:15173,http://localhost:13000

# =====================
# S3-compatible storage (MinIO in dev, Cloudflare R2 in prod)
# =====================
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=changeme_s3
S3_ENDPOINT=minio:9000
S3_BUCKET_NAME=ai3l-uploads
S3_USE_SSL=false
S3_REGION=us-east-1
# Public URL for presigned URLs (browser-accessible). In local dev set to http://localhost:19000.
S3_PUBLIC_URL=http://localhost:19000

# =====================
# MinIO (dev only — used by docker-compose.override.yml)
# =====================
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=changeme_minio

# =====================
# Celery
# =====================
CELERY_BROKER_URL=redis://:${REDIS_PASSWORD}@${REDIS_HOST}:${REDIS_PORT}/1
CELERY_RESULT_BACKEND=redis://:${REDIS_PASSWORD}@${REDIS_HOST}:${REDIS_PORT}/2

# =====================
# VirusTotal (optional: hash-only file scanning)
# =====================
VT_API_KEY=

# =====================
# Sentry
# =====================
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# =====================
# Datadog (enable with: docker compose --profile monitoring up)
# =====================
DD_API_KEY=
DD_SITE=datadoghq.com
DD_AGENT_HOST=datadog-agent
DD_TRACE_ENABLED=false

# =====================
# Super Admin
# =====================
SUPER_ADMIN_USERNAME=superadmin
SUPER_ADMIN_PASSWORD=changeme_admin

# =====================
# Logging
# =====================
LOG_LEVEL=DEBUG  # Set to INFO for production
LOG_FORMAT=json

# =====================
# Production overrides (uncomment for production)
# =====================
# FASTAPI_ENV=production
# FASTAPI_DEBUG=false
# FASTAPI_WORKERS=4
